{
  "$schema": "https://holocron.so/docs.json",
  "name": "Tabwright",
  "description": "Docs for Tabwright, the CLI and MCP that lets agents control your real Chrome browser.",
  "logo": {
    "light": "/logo-square.svg",
    "dark": "/logo-square.svg",
    "href": "/"
  },
  "favicon": {
    "light": "/favicon-32.png",
    "dark": "/favicon-32.png"
  },
  "colors": {
    "primary": "#FF9500",
    "light": "#FF9500",
    "dark": "#FF9500"
  },
  "knownPaths": ["/README", "/api/*", "/login", "/dashboard", "/device"],
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "lucide:book",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "lucide:rocket",
            "pages": ["index", "docs/installation", "docs/cli", "docs/mcp-setup"]
          },
          {
            "group": "Guides",
            "icon": "lucide:book-open",
            "pages": ["docs/remote-access", "docs/troubleshooting"]
          },
          {
            "group": "Comparison",
            "icon": "lucide:git-compare",
            "pages": [
              "docs/vs-chrome-cdp",
              "docs/vs-playwright-mcp",
              "docs/vs-playwright-cli",
              "docs/vs-browser-mcp",
              "docs/vs-claude-extension"
            ]
          },
          {
            "group": "Use Cases",
            "icon": "lucide:lightbulb",
            "pages": ["docs/use-cases"]
          },
          {
            "group": "Reference",
            "icon": "lucide:book-text",
            "pages": ["docs/skill"]
          }
        ]
      },
      {
        "tab": "Cloud Browsers",
        "icon": "lucide:dollar-sign",
        "pages": ["docs/cloud-browsers"]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/Yuyang-Hou/tabwright",
          "placement": "tabs"
        },
        {
          "anchor": "Changelog",
          "icon": "lucide:logs",
          "href": "https://github.com/Yuyang-Hou/tabwright/releases",
          "placement": "tabs"
        }
      ]
    }
  },
  "navbar": {
    "primary": {
      "label": "Cloud Login",
      "href": "/dashboard"
    }
  },
  "footer": {
    "links": [
      {
        "header": "platform",
        "items": [
          { "label": "Rent Cloud Browsers", "href": "/dashboard" },
          { "label": "GitHub", "href": "https://github.com/Yuyang-Hou/tabwright" },
          {
            "label": "Chrome Extension",
            "href": "https://chromewebstore.google.com/detail/tabwright/jfeammnjpkecdekppnclgkkffahnhfhe"
          }
        ]
      }
    ],
    "socials": {
      "github": "https://github.com/Yuyang-Hou/tabwright"
    }
  }
}
