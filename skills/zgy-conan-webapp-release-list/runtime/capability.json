          "type": "object",
          "properties": {
            "key": {
              "type": "string"
            },
            "version": {
              "type": "string"
            },
            "deployStatus": {
              "type": "integer"
            },
            "deployStatusLabel": {
              "type": "string"
            },
            "latestFullVersion": {
              "type": "boolean"
            },
            "latestGrayscaleVersion": {
              "type": "boolean"
            },
            "commitAuthor": {
              "type": "string"
            },
            "commitMessage": {
              "type": "string"
            },
            "commitInfo": {
              "type": "string"
            },
            "commitId": {
              "type": "string"
            },
            "creatorLdap": {
              "type": "string"
            },
            "createTime": {
              "type": [
                "string",
                "null"
              ]
            },
            "deployLdap": {
              "type": [
                "string",
                "null"
              ]
            },
            "deployTime": {
              "type": [
                "string",
                "null"
              ]
            },
            "buildId": {},
            "locked": {
              "type": "boolean"
            },
            "previewUrl": {
              "type": "string"
            },
            "entry": {
              "type": "string"
            },
            "grayscaleData": {}
          }
        }
      }
    },
    "required": [
      "projectName",
      "key",
      "availableKeys",
      "pageInfo",
      "releases"
    ]
