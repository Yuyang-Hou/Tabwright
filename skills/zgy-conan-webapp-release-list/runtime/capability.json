      "https://conan-webapp.zhenguanyu.com/",
      "https://ytkconan.zhenguanyu.com/"
    ],
    "requiredCookieNames": [],
    "failureSignals": [
      "401",
      "403",
      "login",
      "unauthorized"
    ]
  },
