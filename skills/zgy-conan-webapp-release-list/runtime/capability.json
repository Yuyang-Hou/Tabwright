{
  "schemaVersion": 1,
  "id": "zgy-conan-webapp-release-list",
  "title": "ZGY Conan WebApp Release List",
  "description": "",
  "whenToUse": [],
  "whenNotToUse": [],
  "tags": [],
  "match": [],
  "routingHint": "search-first",
  "inputSchema": {
    "type": "object",
    "properties": {
      "projectName": {
        "type": "string",
        "description": "Console project name. Defaults to conan-pedia-web."
      },
      "project": {
        "type": "string",
        "description": "Alias for projectName."
      },
      "key": {
        "type": "string",
        "description": "Specific WebAppKey. Defaults to the first key returned by the project."
      },
      "webAppKey": {
        "type": "string",
        "description": "Alias for key."
      },
      "page": {
        "type": "integer",
        "minimum": 0,
        "description": "Zero-based page index. Defaults to 0."
      },
      "pageSize": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100,
        "description": "Number of releases to return. Defaults to 10."
      }
    },
    "required": []
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "projectName": {
        "type": "string"
      },
      "key": {
        "type": "string"
      },
      "availableKeys": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "pageInfo": {
        "type": "object"
      },
      "latestFullVersion": {},
      "keySummary": {
        "type": [
          "object",
          "null"
        ]
      },
      "releases": {
        "type": "array",
